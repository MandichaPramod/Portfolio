            {
                ageClass = "label-danger";
                ageText = "This Year";
            }
            else
            {
                ageClass = "label-danger";
                ageText = "Over a Year";
            }
        }
    }

    <span class="label label-success" style="margin-right:8px;">
        Last Buy @lastBuyDate
    </span> 
    @if (daysSinceLastBuy.HasValue)
    {
        <span class="label @ageClass" style="
            @(
                daysSinceLastBuy < 15 ? "background-color:#5b9a5d;color:#000;" :
                daysSinceLastBuy < 30 ? "background-color:#a3d9a5;color:#000;" :
                daysSinceLastBuy < 90 ? "background-color:#ffe066;color:#000;" :
                daysSinceLastBuy < 365 ? "background-color:#ffb3b3;color:#000;" :
                 "background-color:#e25f5b;color:#000;"
            )
        ">
            @daysSinceLastBuy days (@ageText)
        </span>
    }
