                            @{
                                var currentMonth = DateTime.Now.Month;
                                var currentYear = DateTime.Now.Year;
                                var thisMonthTransactions = val.Where(x => x.Date.Month == currentMonth && x.Date.Year == currentYear && x.Portfolio == Type && x.Account == item.Account).ToList();
                                var thisMonthTotalCost = thisMonthTransactions.Any() 
                                    ? System.Math.Round(thisMonthTransactions.Sum(x => x.TotalCost), 2) 
                                    : 0;
                                var last3MonthTransactions = val.Where(x => x.Date >= DateTime.Now.AddMonths(-3) && x.Portfolio == Type && x.Account == item.Account).ToList();
                                var last3MonthTotalCost = last3MonthTransactions.Any()
                                    ? System.Math.Round(last3MonthTransactions.Sum(x => x.TotalCost), 2)
                                    : 0;
                                var thisYearTransactions = val.Where(x => x.Date.Year == currentYear && x.Portfolio == Type && x.Account == item.Account).ToList();
                                var thisYearTotalCost = thisYearTransactions.Any()  
                                    ? System.Math.Round(thisYearTransactions.Sum(x => x.TotalCost), 2) 
                                    : 0;
