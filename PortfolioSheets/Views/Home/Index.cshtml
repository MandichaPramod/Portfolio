@{
    ViewData["Title"] = "Home Page";
    int i = 0;
    string Type = "";
    List<BreakDownRow> stockbreakdown;
    @model PortfolioResponseModel;
    List<Portfolio> dict = Model.AllLists["Consolidated"];

    double consolidatedTotalCost = 0;
    double consolidatedCurrentValue = 0;
    double consolidateddividend = 0;
    double consolidatedChange = 0;
    foreach(var items in dict)
    {
        consolidatedTotalCost = consolidatedTotalCost + items.TotalCost;
        consolidatedCurrentValue = consolidatedCurrentValue + items.CurrentValue;
        consolidateddividend = consolidateddividend + items.Dividend;
        consolidatedChange = consolidatedChange + items.Change;
    }

    double consolidatedPnL = consolidatedCurrentValue - consolidatedTotalCost + consolidateddividend;

    Model.MarketCapHistory.Add(new MarketCapHistory()
            {
                Month = DateTime.Now,
                Invested = new MarketCapHistoryRow() { StockMarket = System.Math.Round(consolidatedTotalCost,2) },
                Current = new MarketCapHistoryRow() { StockMarket = System.Math.Round(consolidatedCurrentValue,2) },
                StockMarketPercent =System.Math.Round(((consolidatedCurrentValue - consolidatedTotalCost) * 100 / consolidatedTotalCost), 2)
            });

}
