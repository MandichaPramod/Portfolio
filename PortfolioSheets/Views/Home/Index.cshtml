                            <div class="modal-dialog modal-lg">

                                    <!-- Modal content-->
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <h4 class="modal-title">@item.Name (@item.Symbol)</h4>
                                        </div>
                                        <div class="modal-body">
                                        <div class="p-3 mb-2 bg-dark">
                                            <div class="row font-weight-bold text-muted">
                                                <div class="col-sm-12 bold">BreakDown</div>
                                            </div>
                                            <div class="row font-weight-bold text-muted">
                                                <div class="col small">Quantity</div>
                                                <div class="col small">Date</div>
                                                <div class="col small">Buy Price</div>
                                                <div class="col small">Dividend</div>
                                                <div class="col small">Total Cost</div>
                                                <div class="col small">PnL</div>
                                                <div class="col small">%PnL</div>
                                                <div class="col small">CAGR</div>
                                                <div class="col small">Ageing</div>
                                                <div class="col small">Tags</div>
                                            </div>
                                            @foreach (var transaction in Model.stockTransactions[item.Symbol])
                                            {
                                                @if (transaction.Account == item.Account && transaction.Portfolio == Type)
                                                {
                                                    <div class="row font-weight-bolder text-white">
                                                        <div class="col">@(System.Math.Round(@transaction.Quantity, 4))</div>
                                                        <div class="col">@(transaction.Date.ToShortDateString())</div>
                                                        <div class="col">@(System.Math.Round(@transaction.BuyPrice, 2))</div>
                                                        <div class="col">@(System.Math.Round(@transaction.Dividend, 2))</div>
                                                        <div class="col">@(System.Math.Round(@transaction.TotalCost, 2))</div>
                                                        @if ((transaction.CurrentValue - transaction.TotalCost + transaction.Dividend) > 0)
                                                        {
                                                            @if (((transaction.CurrentValue - transaction.TotalCost + transaction.Dividend) / @transaction.TotalCost) > 10)
                                                            {
                                                                <div class="col" style="font-weight: bolder; color: #5b9a5d;"> @(System.Math.Round((transaction.CurrentValue - transaction.TotalCost + transaction.Dividend), 2))</div>
                                                                <div class="col" style="font-weight: bolder; color: #5b9a5d;"> @(System.Math.Round((((transaction.CurrentValue - transaction.TotalCost + transaction.Dividend) * 100) / transaction.TotalCost), 2))</div>
                                                            }
                                                            else
                                                            {
                                                                <div class="col" style="color: #5b9a5d;">@(System.Math.Round((transaction.CurrentValue - transaction.TotalCost + transaction.Dividend), 2))</div>
                                                                <div class="col" style="color: #5b9a5d;">@(System.Math.Round((((transaction.CurrentValue - transaction.TotalCost + transaction.Dividend) * 100) / transaction.TotalCost), 2))</div>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            @if (((transaction.CurrentValue - transaction.TotalCost + transaction.Dividend) / @transaction.TotalCost) < -10)
                                                            {
                                                                <div class="col" style="font-weight: bold;color: #e25f5b">@(System.Math.Round((transaction.CurrentValue - transaction.TotalCost + transaction.Dividend), 2))</div>
                                                                <div class="col" style="font-weight: bold;color: #e25f5b">@(System.Math.Round((((transaction.CurrentValue - transaction.TotalCost + transaction.Dividend) * 100) / transaction.TotalCost), 2))</div>
                                                            }
                                                            else
                                                            {
                                                                <div class="col" style="color: #e25f5b">@(System.Math.Round((transaction.CurrentValue - transaction.TotalCost + transaction.Dividend), 2)) </div>
                                                                <div class="col" style="color: #e25f5b">@(System.Math.Round((((transaction.CurrentValue - transaction.TotalCost + transaction.Dividend) * 100) / transaction.TotalCost), 2))</div>
                                                            }

                                                        }
                                                        @if((DateTime.Now-transaction.Date).Days /365 >= 1)
                                                        {
                                                            var yearsHeld = (DateTime.Now - transaction.Date).Days / 365.0;
                                                            var cagr = ((transaction.CurrentValue + transaction.Dividend) / transaction.TotalCost);
                                                            cagr = System.Math.Pow(cagr, (1 / yearsHeld)) - 1;
                                                            <div class="col">@(System.Math.Round(cagr * 100, 2))%</div>
                                                        }
                                                        else
                                                        {
                                                            <div class="col">N/A</div>
                                                        }
                                                        <div class="col">@(transaction.Ageing)</div>
                                                        <div class="col">@(transaction.Tag)</div>
                                                    </div>
                                                }
                                            }
                                        </div>
                                        </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-default" data-dismiss="modal">Close</button>
                                    </div>
                                    </div>

                                </div>
                           
                            
                        </div>
                        }

                        
