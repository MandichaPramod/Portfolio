                                    }
                                    else
                                    {
                                        <td data-title="Profit/Loss" class="tg-57iy positive" style="font-weight: bold; color: #5b9a5d;">@(System.Math.Round(@item.PnL, 2))</td>
                                        <td data-title="Profit/Loss" class="tg-57iy positive" style="font-weight: bold; color: #5b9a5d;">@(System.Math.Round(((@item.PnL * 100) / @item.TotalCost), 2))%</td>
