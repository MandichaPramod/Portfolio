        .GroupBy(x => new {  Year = x.Date.Year })
        .Select(g => new { 
            Label = new DateTime(g.Key.Year, 1, 1).ToString("yyyy"), // Format as "yyyy"
            TotalCost = g.Sum(x => x.TotalCost) 
        })
    ));

    // Extract labels and data
    var labels = groupedData.map(g => g.label); // Labels as Month-Year
    var data = groupedData.map(g => g.totalCost); // TotalCost for each group

    // Calculate dynamic Y-axis max
    var maxYValue = Math.ceil(Math.max(...data) * 1.1); // Add 10% padding for visual clarity

var myLineChart = new Chart(ctxYearly, {
  type: 'bar',
  data: {
    labels: labels,
    datasets: [{
      label: "Investment",
      backgroundColor: "rgba(2,117,216,1)",
      borderColor: "rgba(2,117,216,1)",
      data: data,
    }],
  },
  options: {
    scales: {
      xAxes: [{
        time: {
          unit: 'Year'
        },
        gridLines: {
          display: false
        },
        ticks: {
          maxTicksLimit: 6
        }
      }],
      yAxes: [{
        ticks: {
          min: 0,
          max: maxYValue,
          maxTicksLimit: 5
        },
        gridLines: {
          display: true
        }
      }],
    },
    legend: {
      display: false
    }
  }
});
</script>