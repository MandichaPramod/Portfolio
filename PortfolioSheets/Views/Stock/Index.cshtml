<script>// Set new default font family and font color to mimic Bootstrap's default styling
Chart.defaults.global.defaultFontFamily = '-apple-system,system-ui,BlinkMacSystemFont,"Segoe UI",Roboto,"Helvetica Neue",Arial,sans-serif';
Chart.defaults.global.defaultFontColor = '#292b2c';

// Area Chart Example
var ctx = document.getElementById("myAreaChart");
var labels = @Html.Raw(Json.Serialize(Model.stockTransactions.Select(x => x.Date.ToString("MMM d"))));
var data = @Html.Raw(Json.Serialize(Model.stockTransactions.Select(x => x.BuyPrice)));
var currentdata = @Html.Raw(Json.Serialize(Model.stockTransactions.Select(x => x.CurrentValue/x.Quantity)));
var quantity = @Html.Raw(Json.Serialize(Model.stockTransactions.Select(x => x.Quantity)));

// Calculate dynamic Y-axis max
    var maxYValue = Math.ceil(Math.max(Math.max(...data),Math.max(...currentdata)) * 1.1); // Add 10% padding for visual clarity


var myLineChart = new Chart(ctx, {
  type: 'line',
  data: {
    labels: labels,
    datasets: [{
      label: "Buy Price",
      lineTension: 0.3,
      backgroundColor: "rgba(2,117,216,0.2)",
      borderColor: "rgba(2,117,216,1)",
      pointRadius: 5,
      pointBackgroundColor: "rgba(2,117,216,1)",
      pointBorderColor: "rgba(255,255,255,0.8)",
      pointHoverRadius: 5,
      pointHoverBackgroundColor: "rgba(2,117,216,1)",
      pointHitRadius: 50,
      pointBorderWidth: 2,
      data: data,
    },
    {
      label: "Current Price",
      lineTension: 0.3,
      backgroundColor: "rgba(200,117,216,0.2)",
      borderColor: "rgba(200,117,216,1)",
      pointRadius: 5,
      pointBackgroundColor: "rgba(200,117,216,1)",
      pointBorderColor: "rgba(255,255,255,0.8)",
      pointHoverRadius: 5,
      pointHoverBackgroundColor: "rgba(200,117,216,1)",
      pointHitRadius: 50,
      pointBorderWidth: 2,
      data: currentdata,
    },
    {
        label: "Quantity",
        backgroundColor: "rgba(0,0,0,0)", // Transparent background
        borderColor: "rgba(0,0,0,0)", // Transparent line
        pointBackgroundColor: "rgba(0,0,0,0)", // Transparent points
        data: quantity,
    }
    ],
  },
  options: {
    scales: {
      xAxes: [{
        time: {
          unit: 'date'
        },
        gridLines: {
          display: false
        },
        ticks: {
          maxTicksLimit: 7
        }
      }],
      yAxes: [{
        ticks: {
          min: 0,
          max: maxYValue,
          maxTicksLimit: 5
        },
        gridLines: {
          color: "rgba(0, 0, 0, .125)",
        }
      }],
    },
    legend: {
      display: false
    },
    tooltips: {
      mode: 'index', // Show all tooltips at the same x-axis point
      intersect: false // Do not restrict hover to a single point
