<style>
    /* Set height of the grid so .sidenav can be 100% (adjust as needed) */
    .row.content {height: 550px}
    
    /* Set gray background color and 100% height */
    .sidenav {
      background-color: #f1f1f1;
      height: 100%;
    }
        
    /* On small screens, set height to 'auto' for the grid */
    @@media screen and (max-width: 767px) {
      .row.content {height: auto;} 
    }
  </style>


<div class="container-fluid">
  <div class="container mt-5">
    <!-- Stock Details Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <h4 class="card-title">@stockdetails.Name</h4>
                    <p class="card-text">@stockdetails.Symbol</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Stock Overview Section -->
    <div class="row mb-4">
        <div class="col-12">
            <h5 class="text-center mb-3">Stock Overview</h5>
        </div>

        <!-- Current Market Price -->
        <div class="col-md-2 mb-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h6 class="card-title">CMP</h6>
                    <p class="card-text">@stockdetails.CMP</p>
                </div>
            </div>
        </div>

        <!-- Change -->
        <div class="col-md-2 mb-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h6 class="card-title">Change(Change %)</h6>
                    <p class="card-text">@(System.Math.Round(stockdetails.Change, 2))(@stockdetails.ChangePercent%)</p>
                </div>
            </div>
        </div>

        <!-- Volume -->
        <div class="col-md-2 mb-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h6 class="card-title">Volume</h6>
                    <p class="card-text">@(System.Math.Round(stockdetails.Volume, 2))</p>
                </div>
            </div>
        </div>

        <!-- Market Cap -->
        <div class="col-md-2 mb-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h6 class="card-title">Market Cap</h6>
                    <p class="card-text">@stockdetails.MarketCap.ToString("N2")</p>
                </div>
            </div>
        </div>

        <!-- EPS -->
        <div class="col-md-2 mb-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h6 class="card-title">Earnings Per Share</h6>
                    <p class="card-text">@(System.Math.Round(stockdetails.EarningsPerShare, 2))</p>
                </div>
            </div>
        </div>

        <!-- Price to Earnings -->
        <div class="col-md-2 mb-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h6 class="card-title">Price to Earnings</h6>
                    <p class="card-text">@(System.Math.Round(stockdetails.PriceToEarnings, 2))</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">

        <!-- Open -->
        <div class="col-md-2 mb-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h6 class="card-title">Open</h6>
                    <p class="card-text">@stockdetails.Open</p>
                </div>
            </div>
        </div>

        <!-- Previous Close -->
        <div class="col-md-2 mb-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h6 class="card-title">Previous Close</h6>
                    <p class="card-text">@stockdetails.CloseYest</p>
                </div>
            </div>
        </div>

        <!-- High -->
        <div class="col-md-2 mb-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h6 class="card-title">High</h6>
                    <p class="card-text">@stockdetails.High</p>
                </div>
            </div>
        </div>

        <!-- Low -->
        <div class="col-md-2 mb-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h6 class="card-title">low</h6>
                    <p class="card-text">@stockdetails.Low</p>
                </div>
            </div>
        </div>

        <!-- 52W High -->
        <div class="col-md-2 mb-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h6 class="card-title">52W High</h6>
                    <p class="card-text">@(System.Math.Round(stockdetails.High52W, 2))</p>
                </div>
            </div>
        </div>

        <!-- 52W Low -->
        <div class="col-md-2 mb-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h6 class="card-title">52W Low</h6>
                    <p class="card-text">@(System.Math.Round(stockdetails.Low52W, 2))</p>
                </div>
            </div>
        </div>

        
    </div>


    <!-- Active Overview Section -->
    <div class="row mb-4">
        <div class="col-12">
            <h5 class="text-center mb-3">Active Overview</h5>
        </div>

        <!-- Total Quantity -->
        <div class="col-md-3 mb-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h6 class="card-title">Total Quantity</h6>
                    <p class="card-text">@Quantity</p>
                </div>
            </div>
        </div>

        <!-- Total Invested -->
        <div class="col-md-3 mb-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h6 class="card-title">Total Invested</h6>
                    <p class="card-text">@(System.Math.Round(TotalCost, 2))</p>
                </div>
            </div>
        </div>

        <!-- Current Value -->
        <div class="col-md-3 mb-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h6 class="card-title">Current Value</h6>
                    <p class="card-text">@(System.Math.Round(CurrentValue, 2))</p>
                </div>
            </div>
        </div>

        <!-- Unrealized Profit/Loss -->
        <div class="col-md-3 mb-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h6 class="card-title">Unrealized Profit/Loss</h6>
                    <p class="card-text">@(System.Math.Round(TotalPnL, 2))</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Realized Financials Section -->
    <div class="row">
        <div class="col-12">
            <h5 class="text-center mb-3">Realized Info</h5>
        </div>

        <!-- Realized Buy -->
        <div class="col-md-3 mb-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h6 class="card-title">Realized Buy</h6>
                    <p class="card-text">@(System.Math.Round(positionalBuy, 2))</p>
                </div>
            </div>
        </div>

        <!-- Realized Sell -->
        <div class="col-md-3 mb-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h6 class="card-title">Realized Sell</h6>
                    <p class="card-text">@(System.Math.Round(positionalSell, 2))</p>
                </div>
            </div>
        </div>

        <!-- Realized Profit/Loss -->
        <div class="col-md-3 mb-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h6 class="card-title">Realized Profit/Loss</h6>
                    <p class="card-text">@(System.Math.Round(realisedProfit, 2))</p>
                </div>
            </div>
        </div>

        <!-- Profit After Charges -->
        <div class="col-md-3 mb-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h6 class="card-title">Profit After Charges</h6>
                    <p class="card-text">@(System.Math.Round(realisedProfitafterCharges, 2))</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Realized Delivery Financials Section -->
    <div class="row">
        <div class="col-12">
            <h5 class="text-center mb-3">Realized Delivery Info</h5>
        </div>

        <!-- Realized Buy -->
        <div class="col-md-3 mb-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h6 class="card-title">Realized Delivery Buy</h6>
                    <p class="card-text">@(System.Math.Round(DeliverypositionalBuy, 2))</p>
                </div>
            </div>
        </div>

        <!-- Realized Sell -->
        <div class="col-md-3 mb-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h6 class="card-title">Realized Delivery Sell</h6>
                    <p class="card-text">@(System.Math.Round(DeliverypositionalSell, 2))</p>
                </div>
            </div>
        </div>

        <!-- Realized Profit/Loss -->
        <div class="col-md-3 mb-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h6 class="card-title">Realized Delivery Profit/Loss</h6>
                    <p class="card-text">@(System.Math.Round(DeliveryrealisedProfit, 2))</p>
                </div>
            </div>
        </div>

        <!-- Profit After Charges -->
        <div class="col-md-3 mb-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h6 class="card-title">Profit After Charges</h6>
                    <p class="card-text">@(System.Math.Round(DeliveryrealisedProfitafterCharges, 2))</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Realized Intraday Financials Section -->
    <div class="row">
        <div class="col-12">
            <h5 class="text-center mb-3">Realized Intraday Info</h5>
        </div>

        <!-- Realized Buy -->
        <div class="col-md-3 mb-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h6 class="card-title">Realized Intraday Buy</h6>
                    <p class="card-text">@(System.Math.Round(IntradaypositionalBuy, 2))</p>
                </div>
            </div>
        </div>

        <!-- Realized Sell -->
        <div class="col-md-3 mb-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h6 class="card-title">Realized Intraday Sell</h6>
                    <p class="card-text">@(System.Math.Round(IntradaypositionalSell, 2))</p>
                </div>
            </div>
        </div>

        <!-- Realized Profit/Loss -->
        <div class="col-md-3 mb-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h6 class="card-title">Realized Intraday Profit/Loss</h6>
                    <p class="card-text">@(System.Math.Round(IntradayrealisedProfit, 2))</p>
                </div>
            </div>
        </div>

        <!-- Profit After Charges -->
        <div class="col-md-3 mb-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h6 class="card-title">Profit After Charges</h6>
                    <p class="card-text">@(System.Math.Round(IntradayrealisedProfitafterCharges, 2))</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Dividends Section -->
    <div class="row">
        <div class="col-12">
            <h5 class="text-center mb-3">Dividends Info</h5>
        </div>

        <!-- Dividend Unrealized -->
        <div class="col-md-3 mb-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h6 class="card-title">Dividend Unrealized</h6>
                    <p class="card-text">@(System.Math.Round(Dividend ,2))</p>
                </div>
            </div>
        </div>

        <!-- Dividend realised -->
        <div class="col-md-3 mb-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h6 class="card-title">Dividend Realized</h6>
                    <p class="card-text">@(System.Math.Round(realisedDividend ,2))</p>
                </div>
            </div>
        </div>

        <!-- Reinvested -->
        <div class="col-md-3 mb-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h6 class="card-title">Reinvested</h6>
                    <p class="card-text">@(System.Math.Round(DividendReinvest, 2))</p>
                </div>
            </div>
        </div>

        <!-- Dividend from Bank -->
        <div class="col-md-3 mb-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h6 class="card-title">Dividend(from Bank)</h6>
                    <p class="card-text">@(System.Math.Round(bankDividend, 2))</p>
                </div>
            </div>
        </div>

    </div>
</div>

</div>

<div id="layoutSidenav">
    <div id="layoutSidenav_content">
                <main>
                    <div class="container-fluid px-4">
                       
                        <!--Row1-->
                        <div class="row">
                            <div class="col-xl-6">
                                <div class="card mb-4">
                                    <div class="card-header">
                                        <i class="fas fa-chart-area me-1"></i>
                                        Investments
                                    </div>
                                    <div class="card-body"><canvas id="myAreaChart" width="100%" height="40"></canvas></div>
                                </div>
                            </div>
                            <div class="col-xl-6">
                                <div class="card mb-4">
                                    <div class="card-header">
                                        <i class="fas fa-chart-bar me-1"></i>
                                        Yearly Chart
                                    </div>
                                    <div class="card-body"><canvas id="myBarChartYearly" width="100%" height="40"></canvas></div>
                                </div>
                            </div>
                        </div>

                        <!--Row2-->
                        <div class="row">
                            <div class="col-xl-12"> 
                                <div class="card mb-4">
                                    <div class="card-header">
                                        <i class="fas fa-chart-bar me-1"></i>
                                        Monthly Chart
                                    </div>
                                    <div class="card-body"><canvas id="myBarChart" width="100%" height="40"></canvas></div>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                        <div class="card mb-4">
                            <div class="card-header">
                                <i class="fas fa-table me-1"></i>
                                Investment History
                            </div>
                            <div class="card-body">
                                <table id="datatablesSimple">
                                    <thead>
                                        <tr>
                                            <th class="tg-amwm">Date</th>
                                            <th class="tg-amwm">Quantity</th>
                                            <th class="tg-amwm">Buy Price</th>
                                            <th class="tg-amwm">Total Cost</th>
                                            <th class="tg-amwm">Current Value</th>
                                            <th class="tg-amwm">Profit/Loss</th>
                                            <th class="tg-amwm">Dividend</th>
                                            <th class="tg-amwm">Dividend Reinvestment</th>
                                            <th class="tg-amwm">Portfolio</th>
                                            <th class="tg-amwm">Tag</th>
                                            <th class="tg-amwm">Ageing</th>
                                        </tr>
                                    </thead>
                                    <tfoot>
                                        <tr>
                                             <th class="tg-amwm">Date</th>
                                            <th class="tg-amwm">Quantity</th>
                                            <th class="tg-amwm">Buy Price</th>
                                            <th class="tg-amwm">Total Cost</th>
                                            <th class="tg-amwm">Current Value</th>
                                            <th class="tg-amwm">Profit/Loss</th>
                                            <th class="tg-amwm">Dividend</th>
                                            <th class="tg-amwm">Dividend Reinvestment</th>
                                            <th class="tg-amwm">Portfolio</th>
                                            <th class="tg-amwm">Tag</th>
                                            <th class="tg-amwm">Ageing</th>
                                        </tr>
                                    </tfoot>
                                    <tbody>
                                         @foreach (var transaction in Model.stockTransactions)
                                        {
                                        <tr>
                                            <td class="tg-57iy">@(transaction.Date.ToShortDateString())</td>
                            <td class="tg-57iy">@(System.Math.Round(@transaction.Quantity, 4))</td>
                            <td class="tg-57iy">@(System.Math.Round(@transaction.BuyPrice, 2))</td>  
                            <td class="tg-57iy">@(System.Math.Round(@transaction.TotalCost, 2))</td>
                            <td class="tg-57iy">@(System.Math.Round(@transaction.CurrentValue, 2))</td>
                            
                            @if ((transaction.CurrentValue-transaction.TotalCost) > 0)
                            {
                                @if ((System.Math.Round((((transaction.CurrentValue-transaction.TotalCost)) / transaction.TotalCost), 2)) > 10)
                                {
                                    <td class="tg-57iy positive" style="font-weight: bold; color: #5b9a5d;">@(System.Math.Round((transaction.CurrentValue-transaction.TotalCost), 2)) (@(System.Math.Round((((transaction.CurrentValue-transaction.TotalCost) * 100) / @transaction.TotalCost), 2))%)</td>
                                }
                                else
                                {
                                    <td class="tg-57iy positive" style="font-weight: bold; color: #5b9a5d;">@(System.Math.Round((transaction.CurrentValue-transaction.TotalCost), 2)) (@(System.Math.Round((((transaction.CurrentValue-transaction.TotalCost) * 100) / @transaction.TotalCost), 2))%)</td>
                                }
                            }
                            else
                            {
                                @if ((System.Math.Round((((transaction.CurrentValue-transaction.TotalCost)) / 100), 2)) < -10)
                                {
                                    <td class="tg-57iy" style="font-weight: bold;color: #e25f5b">@(System.Math.Round((transaction.CurrentValue-transaction.TotalCost), 2)) (@(System.Math.Round((((transaction.CurrentValue-transaction.TotalCost) * 100) / @transaction.TotalCost), 2))%)</td>
                                }
                                else
                                {
                                    <td class="tg-57iy" style="color: #e25f5b">@(System.Math.Round((transaction.CurrentValue-transaction.TotalCost), 2)) (@(System.Math.Round((((transaction.CurrentValue-transaction.TotalCost) * 100) / @transaction.TotalCost), 2))%)</td>
                                }

                            }
                            <td class="tg-57iy">@(System.Math.Round(@transaction.Dividend, 2))</td>
                            <td class="tg-57iy">@(System.Math.Round(@transaction.DividendReinvestment, 2))</td>
                            <td class="tg-57iy">@transaction.Portfolio</td>
                            <td class="tg-57iy">@transaction.Tag</td>
                            <td class="tg-57iy">@transaction.Ageing</td>
                                        </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        </div>
                        <div class="row">
                         <div class="card mb-4">
                            <div class="card-header">
                                <i class="fas fa-table me-1"></i>
