@{
    
    @model StockDetailsResponseModel;

    ViewData["Title"] = $"{Model.stockdetails.Name} Details";

    double TotalCost = 0;
    double CurrentValue = 0;
    double TotalPnL = 0;
    double Dividend = 0;
    double DividendReinvest = 0;
    double Quantity = 0;

    var yearlyStocks = new List<BreakDownRow>();
    var monthlyStocks = new List<BreakDownRow>();
    var stockdetails = Model.stockdetails;

    foreach (var items in Model.stockTransactions)
    {
        Quantity = Quantity + items.Quantity;
        TotalCost = TotalCost + items.TotalCost;
        CurrentValue = CurrentValue + items.CurrentValue;
        TotalPnL = CurrentValue - TotalCost;
        Dividend = Dividend + items.Dividend;
        DividendReinvest = DividendReinvest + items.DividendReinvestment;

        if(yearlyStocks.Any(x=>x.Date.Year == items.Date.Year))
        {
            var pf = yearlyStocks.First(x => x.Date.Year ==  items.Date.Year);

                    
            pf.CurrentValue = pf.CurrentValue+items.CurrentValue;
            pf.Dividend = pf.Dividend+items.Dividend;
            pf.TotalCost = pf.TotalCost+items.TotalCost;
            pf.DividendReinvestment = pf.DividendReinvestment+items.DividendReinvestment;
        }
        else
        {
            yearlyStocks.Add(new BreakDownRow()
            {
                Date = items.Date,
                CurrentValue = items.CurrentValue,
                Dividend = items.Dividend,
                TotalCost = items.TotalCost,
                DividendReinvestment = items.DividendReinvestment,
            });
        }
        if(monthlyStocks.Any(x=>x.Date.Year == items.Date.Year && x.Date.Month == items.Date.Month))
        {
            var pf = monthlyStocks.First(x => x.Date.Year ==  items.Date.Year && x.Date.Month == items.Date.Month);

                    
            pf.CurrentValue = pf.CurrentValue+items.CurrentValue;
            pf.Dividend = pf.Dividend+items.Dividend;
            pf.TotalCost = pf.TotalCost+items.TotalCost;
            pf.DividendReinvestment = pf.DividendReinvestment+items.DividendReinvestment;
        }
        else
        {
            monthlyStocks.Add(new BreakDownRow()
            {
                Date = items.Date,
                CurrentValue = items.CurrentValue,
                Dividend = items.Dividend,
                TotalCost = items.TotalCost,
                DividendReinvestment = items.DividendReinvestment,
            });
        }
    }

    double positionalBuy = 0;
    double positionalSell = 0;
    double realisedProfit = 0;
    double realisedProfitafterCharges = 0;
    double realisedDividend = 0;

    double DeliverypositionalBuy = 0;
    double DeliverypositionalSell = 0;
    double DeliveryrealisedProfit = 0;
    double DeliveryrealisedProfitafterCharges = 0;
    double DeliveryrealisedDividend = 0;

    double IntradaypositionalBuy = 0;
    double IntradaypositionalSell = 0;
    double IntradayrealisedProfit = 0;
    double IntradayrealisedProfitafterCharges = 0;
    double IntradayrealisedDividend = 0;

    foreach (var items in Model.stockTrades)
    {
        positionalBuy = positionalBuy + items.TotalCost;
        positionalSell = positionalSell + items.SellValue;
        realisedProfit = realisedProfit + items.PnL;
        realisedProfitafterCharges = realisedProfitafterCharges + items.PnLAfterCharges;
        realisedDividend = realisedDividend + items.Dividend;

        if(items.Type == "Delivery")
        {
            DeliverypositionalBuy = DeliverypositionalBuy + items.TotalCost;
            DeliverypositionalSell = DeliverypositionalSell + items.SellValue;
            DeliveryrealisedProfit = DeliveryrealisedProfit + items.PnL;
            DeliveryrealisedProfitafterCharges = DeliveryrealisedProfitafterCharges + items.PnLAfterCharges;
            DeliveryrealisedDividend = DeliveryrealisedDividend + items.Dividend;
        }
        else if(items.Type == "Intraday")
        {
            IntradaypositionalBuy = IntradaypositionalBuy + items.TotalCost;
            IntradaypositionalSell = IntradaypositionalSell + items.SellValue;
            IntradayrealisedProfit = IntradayrealisedProfit + items.PnL;
            IntradayrealisedProfitafterCharges = IntradayrealisedProfitafterCharges + items.PnLAfterCharges;
            IntradayrealisedDividend = IntradayrealisedDividend + items.Dividend;
        }
    }

    double bankDividend = 0;
    foreach (var items in Model.dividendDetails)
    {
        bankDividend = bankDividend + items.Dividend;
    }
}
