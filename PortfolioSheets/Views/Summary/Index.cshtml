<script>
    $(document).ready(function () {
        $("#search").on("keyup", function () {
            var value = $(this).val().toLowerCase();
            $("#consolidatedbody tr").filter(function () {
                $(this).toggle($(this).text()
                    .toLowerCase().indexOf(value) > -1)
            });
        });
    });

    // Data passed from the model to JavaScript
        const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ChartData.Select(x => x.Label + " ("+x.Percent+")")));
        const values = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ChartData.Select(x => x.Value)));

        const total = values.reduce((sum, value) => sum + value, 0);

        // Chart.js setup
        const ctx = document.getElementById('donutChart').getContext('2d');
        new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: labels, // Labels for the chart
                datasets: [{
                    data: values, // PnL values
                    backgroundColor: [
                        '#FF6384', '#36A2EB', '#FFCE56', '#4BC0C0', '#9966FF', '#FF9F40',
                        '#FF5733', '#33FF57', '#3357FF', '#F5A623', '#B10DC9', '#FF851B',
                        '#85144b', '#2ECC40', '#39CCCC', '#01FF70', '#FFDC00', '#F012BE',
                        '#3D9970', '#111111', '#AAAAAA'
                    ], // Color palette (add more if needed)
                    hoverBackgroundColor: [
                        '#FF6384', '#36A2EB', '#FFCE56', '#4BC0C0', '#9966FF', '#FF9F40',
                        '#FF5733', '#33FF57', '#3357FF', '#F5A623', '#B10DC9', '#FF851B',
                        '#85144b', '#2ECC40', '#39CCCC', '#01FF70', '#FFDC00', '#F012BE',
                        '#3D9970', '#111111', '#AAAAAA'
                    ]
                }]
            },
            options: {
                responsive: true,
                legend: {
                        position: 'right',
                    },
                plugins: {
                    
                    tooltip: {
                        callbacks: {
                            label: function(tooltipItem) {
                                const label = tooltipItem.label || '';
                                const value = tooltipItem.raw;
                                const percentage = ((value / total) * 100).toFixed(2); // Calculate percentage
                                return `${label}: ${value} (${percentage}%)`
                            }
                        }
                    }
                }
            }
        });

