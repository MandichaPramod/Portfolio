@{
    ViewData["Title"] = "Summary";
    int i = 0;
    string Type = "";
    List<BreakDownRow> stockbreakdown;
    @model PortfolioResponseModel;
    List<Portfolio> dict = Model.AllLists["Consolidated"];

    double consolidatedTotalCost = 0;
    double consolidatedCurrentValue = 0;
    double consolidateddividend = 0;
    double consolidatedChange = 0;
    foreach(var items in dict)
    {
        consolidatedTotalCost = consolidatedTotalCost + items.TotalCost;
        consolidatedCurrentValue = consolidatedCurrentValue + items.CurrentValue;
        consolidateddividend = consolidateddividend + items.Dividend;
        consolidatedChange = consolidatedChange + items.Change;
    }

    double consolidatedPnL = consolidatedCurrentValue - consolidatedTotalCost + consolidateddividend;

    Model.MarketCapHistory.Add(new MarketCapHistory()
            {
                Month = DateTime.Now,
                Invested = new MarketCapHistoryRow() { StockMarket = System.Math.Round(consolidatedTotalCost,2) },
                Current = new MarketCapHistoryRow() { StockMarket = System.Math.Round(consolidatedCurrentValue,2) },
                StockMarketPercent =System.Math.Round(((consolidatedCurrentValue - consolidatedTotalCost) * 100 / consolidatedTotalCost), 2)
            });

     // Sort transactions by PnL in descending order
    var sortedTransactions = dict
        .OrderByDescending(x => x.PnL)
        .ToList();

    // Select the top 20
    // Calculate total PnL
    var totalPnL = sortedTransactions.Sum(x => x.PnL);

    // Select the top 20
    var top20 = sortedTransactions
        .Take(9)
        .Select(x => new ChartData
        {
            Label = x.Symbol,
            Value = System.Math.Round(x.PnL,2),
            Percent = $"{((double)x.PnL / totalPnL * 100).ToString("0.00")}%"
        })
        .ToList();

    // Calculate the sum of remaining PnL and add as "Others"
    var othersSum = sortedTransactions.Skip(9).Sum(x => x.PnL);
    if (othersSum > 0)
    {
        top20.Add(new ChartData
        {
            Label = "Others",
            Value = System.Math.Round(othersSum,2),
            Percent = $"{((double)othersSum / totalPnL * 100).ToString("0.00")}%"
        });
    }

    List<ChartData> ChartData = top20;

    sortedTransactions = dict
        .OrderByDescending(x => x.TotalCost)
        .ToList();

    // Select the top 20
    // Calculate total PnL
    var totalCost = sortedTransactions.Sum(x => x.TotalCost);

    // Select the top 20
    top20 = sortedTransactions
        .Take(9)
        .Select(x => new ChartData
        {
            Label = x.Symbol,
            Value = System.Math.Round(x.TotalCost,2),
            Percent = $"{((double)x.TotalCost / totalCost * 100).ToString("0.00")}%"
        })
        .ToList();

    // Calculate the sum of remaining PnL and add as "Others"
    othersSum = sortedTransactions.Skip(9).Sum(x => x.TotalCost);
    if (othersSum > 0)
    {
        top20.Add(new ChartData
        {
            Label = "Others",
            Value = System.Math.Round(othersSum,2),
            Percent = $"{((double)othersSum / totalCost * 100).ToString("0.00")}%"
        });
    }

    List<ChartData> ChartData2 = top20;

    var sortedTransactionsByProfitPercentage = dict
                .Select(x => new
                {
                    x.Symbol,
                    ProfitPercentage = System.Math.Round((x.PnL * 100) / x.TotalCost, 2)
                })
                .OrderByDescending(x => x.ProfitPercentage)
                .ToList();

   

    // Select the top 20
    top20 = sortedTransactionsByProfitPercentage
        .Take(10)
        .Select(x => new ChartData
        {
            Label = x.Symbol,
            Value = x.ProfitPercentage
        })
        .ToList();

   

    List<ChartData> ChartData3 = top20;

    sortedTransactions = dict
        .OrderByDescending(x => x.Change)
        .ToList();

    // Select the top 20

    // Select the top 20
    top20 = sortedTransactions
        .Take(8)
        .Select(x => new ChartData
        {
            Label = x.Symbol,
            Value = System.Math.Round(x.Change,2)
        })
        .ToList();

    List<ChartData> ChartData4 = top20;

    sortedTransactionsByProfitPercentage = dict
                .Select(x => new
                {
                    x.Symbol,
                    ProfitPercentage = System.Math.Round(100 * x.Change / (x.CurrentValue - x.Change), 2)
                })
                .OrderByDescending(x => x.ProfitPercentage)
                .ToList();

    // Select the top 20

    // Select the top 20
    top20 = sortedTransactionsByProfitPercentage
        .Take(8)
        .Select(x => new ChartData
        {
            Label = x.Symbol,
            Value = System.Math.Round(x.ProfitPercentage,2)
        })
        .ToList();

    List<ChartData> ChartData5 = top20;

    sortedTransactions = dict
        .OrderBy(x => x.Change)
        .ToList();

    // Select the top 20

    // Select the top 20
    top20 = sortedTransactions
        .Take(8)
        .Select(x => new ChartData
        {
            Label = x.Symbol,
            Value = System.Math.Round(x.Change,2)
        })
        .ToList();

    List<ChartData> ChartData6 = top20;

    sortedTransactionsByProfitPercentage = dict
                .Select(x => new
                {
                    x.Symbol,
                    ProfitPercentage = System.Math.Round(100 * x.Change / (x.CurrentValue - x.Change), 2)
                })
                .OrderBy(x => x.ProfitPercentage)
                .ToList();

    // Select the top 20

    // Select the top 20
    top20 = sortedTransactionsByProfitPercentage
        .Take(8)
        .Select(x => new ChartData
        {
            Label = x.Symbol,
            Value = System.Math.Round(x.ProfitPercentage,2)
        })
        .ToList();

    List<ChartData> ChartData7 = top20;

    //chart 10
    var mutualfunds = Model.AllLists["Mutual Fund"];
    var stocks = Model.AllLists["Free Stock"];
    stocks.AddRange(Model.AllLists["Long Term"]);
    stocks.AddRange(Model.AllLists["Stock SIP"]);
    stocks.AddRange(Model.AllLists[ "Trading"]);

    var etf = Model.AllLists["ETF SIP"];

    var usstocks = Model.AllLists["US Free Stocks"];
    usstocks.AddRange(Model.AllLists["US Stocks"]);

    var usEtf = Model.AllLists["US ETF"];

    // Select the top 20
    // Calculate total PnL
    totalPnL = mutualfunds.Sum(x => x.PnL);
    totalCost = mutualfunds.Sum(x => x.TotalCost);

    top20 = new List<ChartData>(){
        new ChartData()
        {
            Label = "Mutual Fund",
            Value = totalPnL
        } };

    totalPnL = stocks.Sum(x => x.PnL);
    top20.Add( new ChartData() { Label = "Stocks", Value = totalPnL } ); 

    totalPnL = etf.Sum(x => x.PnL);
    top20.Add( new ChartData() { Label = "ETF", Value = totalPnL } );

    totalPnL = usstocks.Sum(x => x.PnL);
    top20.Add( new ChartData() { Label = "US Stocks", Value = totalPnL } );

    totalPnL = usEtf.Sum(x => x.PnL);
    top20.Add( new ChartData() { Label = "US ETF", Value = totalPnL } );

    double totalValue = top20.Sum(item => item.Value);

    // Update Percent for each item
    foreach (var item in top20)
    {
        item.Percent = (totalValue == 0) ? "0" : ((item.Value / totalValue) * 100).ToString(("0.00"))+"%";
    }
    List<ChartData> ChartData10 = top20;

    top20 = new List<ChartData>(){
        new ChartData()
        {
            Label = "Mutual Fund",
            Value = totalCost
        } };

    totalCost = stocks.Sum(x => x.TotalCost);
    top20.Add( new ChartData() { Label = "Stocks", Value = totalCost } ); 

    totalCost = etf.Sum(x => x.TotalCost);
    top20.Add( new ChartData() { Label = "ETF", Value = totalCost } );

    totalCost = usstocks.Sum(x => x.TotalCost);
    top20.Add( new ChartData() { Label = "US Stocks", Value = totalCost } );

    totalCost = usEtf.Sum(x => x.TotalCost);
    top20.Add( new ChartData() { Label = "US ETF", Value = totalCost } );

    totalValue = top20.Sum(item => item.Value);

    // Update Percent for each item
    foreach (var item in top20)
    {
        item.Percent = (totalValue == 0) ? "0" : ((item.Value / totalValue) * 100).ToString(("0.00"))+"%";
    }
    List<ChartData> ChartData11 = top20;


}
