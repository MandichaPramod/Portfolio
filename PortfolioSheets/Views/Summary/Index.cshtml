var data8 = @Html.Raw(Json.Serialize(Model.MarketCapHistory.Select(x => x.Invested.StockMarket)));
var currentdata8 = @Html.Raw(Json.Serialize(Model.MarketCapHistory.Select(x => x.Current.StockMarket)));
var percent8 = @Html.Raw(Json.Serialize(Model.MarketCapHistory.Select(x => x.StockMarketPercent)));

// Calculate dynamic Y-axis max
    var maxYValue = Math.ceil(Math.max(Math.max(...data8),Math.max(...currentdata8)) * 1.1); // Add 10% padding for visual clarity


var myLineChart = new Chart(ctx8, {
  type: 'line',
  data: {
    labels: labels8,
    datasets: [{
      label: "Buy Price",
      lineTension: 0.3,
      backgroundColor: "rgba(2,117,216,0.2)",
      borderColor: "rgba(2,117,216,1)",
      pointRadius: 5,
      pointBackgroundColor: "rgba(2,117,216,1)",
      pointBorderColor: "rgba(255,255,255,0.8)",
      pointHoverRadius: 5,
      pointHoverBackgroundColor: "rgba(2,117,216,1)",
      pointHitRadius: 50,
      pointBorderWidth: 2,
      data: data8,
    },
    {
      label: "Current Price",
      lineTension: 0.3,
      backgroundColor: "rgba(200,117,216,0.2)",
      borderColor: "rgba(200,117,216,1)",
      pointRadius: 5,
      pointBackgroundColor: "rgba(200,117,216,1)",
      pointBorderColor: "rgba(255,255,255,0.8)",
      pointHoverRadius: 5,
      pointHoverBackgroundColor: "rgba(200,117,216,1)",
      pointHitRadius: 50,
      pointBorderWidth: 2,
      data: currentdata8,
    },
    {
        label: "Percent",
        backgroundColor: "rgba(0,0,0,0)", // Transparent background
        borderColor: "rgba(0,0,0,0)", // Transparent line
        pointBackgroundColor: "rgba(0,0,0,0)", // Transparent points
        data: percent8,
    }
    ],
  },
  options: {
    scales: {
      xAxes: [{
        time: {
          unit: 'date'
        },
        gridLines: {
          display: false
        },
        ticks: {
          maxTicksLimit: 7
        }
      }],
      yAxes: [{
          beginAtZero: false,
        ticks: {
          min: 600000,
          max: maxYValue,
          maxTicksLimit: 5
        },
        gridLines: {
          color: "rgba(0, 0, 0, .125)",
        }
      }],
    },
    legend: {
      display: false
    },
    tooltips: {
      mode: 'index', // Show all tooltips at the same x-axis point
      intersect: false // Do not restrict hover to a single point
    },
    responsive: true,
    maintainAspectRatio: false
  }
});

